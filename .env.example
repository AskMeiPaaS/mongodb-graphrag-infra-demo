# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=infrastructure_graph

# VoyageAI Configuration (for embeddings)
# Get your API key from: https://www.voyageai.com/
VOYAGE_API_KEY=your_voyageai_api_key_here
VOYAGE_EMBEDDING_MODEL=voyage-2

# Anthropic Configuration (for LLM)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Vector Configuration
# voyage-2 produces 1024-dimensional vectors
VECTOR_DIMENSIONS=1024
